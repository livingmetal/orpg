// ORPG data model (SQLite — embedded, no separate DB server).
// The host program applies migrations on startup, so running the host
// brings the database up automatically.
//
// Run `npm run db:generate` after editing the schema, and
// `npm run db:migrate` to create/apply a migration during development.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Users ────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  // scrypt hash ("salt:hash"); set on first credentials sign-in.
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  characters  Character[]
  gmSessions  GameSession[]   @relation("GameMaster")
  memberships SessionMember[]
  messages    ChatMessage[]
  diceRolls   DiceRoll[]
}

// ── Characters & sheets ──────────────────────────────
model Character {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The sheet system (stats, skills, inventory...) is rule-system dependent,
  // so it is stored as flexible JSON for now. Tighten per-system later.
  // (SQLite has no DB-level default for Json; callers pass `{}` on create.)
  sheet Json

  messages  ChatMessage[]
  diceRolls DiceRoll[]
  sessions  SessionMember[]
}

// ── Sessions (a game table) ──────────────────────────
model GameSession {
  id          String   @id @default(cuid())
  title       String
  description String?
  // SessionStatus: DRAFT | OPEN | IN_PROGRESS | CLOSED (SQLite has no enums)
  status      String   @default("DRAFT")
  gmId        String
  gm          User     @relation("GameMaster", fields: [gmId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     SessionMember[]
  storyboards Storyboard[]
  messages    ChatMessage[]
  diceRolls   DiceRoll[]
}

model SessionMember {
  id          String      @id @default(cuid())
  sessionId   String
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId String?
  character   Character?  @relation(fields: [characterId], references: [id], onDelete: SetNull)
  // SessionRole: GM | PLAYER | SPECTATOR
  role        String      @default("PLAYER")
  joinedAt    DateTime    @default(now())

  @@unique([sessionId, userId])
}

// ── Storyboards (GM-authored, published per session) ─
model Storyboard {
  id        String      @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title     String
  body      String
  order     Int         @default(0)
  published Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// ── Chat & dice (the live table log) ─────────────────
model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  characterId String?
  character   Character?  @relation(fields: [characterId], references: [id], onDelete: SetNull)
  // MessageKind: CHAT | SYSTEM | DICE | GM_NARRATION | LLM_ASSIST
  kind        String      @default("CHAT")
  content     String
  createdAt   DateTime    @default(now())

  @@index([sessionId, createdAt])
}

model DiceRoll {
  id          String      @id @default(cuid())
  sessionId   String
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  characterId String?
  character   Character?  @relation(fields: [characterId], references: [id], onDelete: SetNull)
  notation    String // e.g. "2d6+3"
  results     Json // per-die results
  total       Int
  createdAt   DateTime    @default(now())

  @@index([sessionId, createdAt])
}
