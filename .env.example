# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (SQLite — embedded, no separate server) ─
# Path is relative to the prisma/ directory. The host program creates and
# migrates this file automatically on startup.
DATABASE_URL="file:../data/orpg.db"

# ── Auth (NextAuth) ──────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# ── LLM (Anthropic) ──────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# Default model used by the assist endpoint
ANTHROPIC_MODEL="claude-opus-4-8"
