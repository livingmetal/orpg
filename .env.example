# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (Postgres) ──────────────────────────────
# Local dev example: postgresql://orpg:orpg@localhost:5432/orpg
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/orpg?schema=public"

# ── Auth (NextAuth) ──────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# ── LLM (Anthropic) ──────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# Default model used by the assist endpoint
ANTHROPIC_MODEL="claude-opus-4-8"
