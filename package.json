{
  "name": "orpg",
  "version": "0.1.0",
  "private": true,
  "description": "Online Role-Playing Game platform — realtime chat, dice, character sheets, GM storyboards, and LLM assist.",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.5.0",
    "next": "^15.2.0",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.0",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
